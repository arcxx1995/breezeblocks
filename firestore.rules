rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /matchmakingQueue/{queueEntryId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.guestId == request.auth.uid
      );
      allow write: if false;
    }

    match /games/{gameId} {
      allow read: if signedIn() && request.auth.uid in resource.data.playerIds;
      allow write: if false;

      match /{document=**} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.playerIds;
        allow write: if false;
      }
    }

    match /matchHistory/{matchId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
